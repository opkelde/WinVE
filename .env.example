# Home Assistant Assist Settings
# Copy this file to .env and fill in your actual values

# === CONNECTION MODE ===
# Choose how WinVE connects/interacts with Home Assistant:
#   esphome    — HA connects to WinVE as an ESPHome device (timers, conversation mode) [Default]
#   websocket  — WinVE connects to HA (optional, used for HA volume ducking integration)
CONNECTION_MODE=esphome

# === WEBSOCKET MODE (CONNECTION_MODE=websocket) ===
# Your Home Assistant server address (with port if not 80/443)
HA_HOST=your-homeassistant.local:8123
# Long-lived access token from HA Profile settings
HA_TOKEN=your_long_lived_access_token_here
# Optional: Specific pipeline ID (leave empty for default)
HA_PIPELINE_ID=

# === ESPHOME SATELLITE MODE (CONNECTION_MODE=esphome) ===
# Device name shown in Home Assistant device list
DEVICE_NAME=WinVE
# TCP port that HA connects to (default 6053, standard ESPHome port)
ESPHOME_PORT=6053
# Optional: stable MAC address for device identity (auto-generated if empty)
DEVICE_MAC=

# === ACTIVATION ===
# Hotkey combination to activate voice assistant
HA_HOTKEY=ctrl+shift+g

# === AUDIO ===
# Sample rate for audio recording (8000, 16000, 32000)
HA_SAMPLE_RATE=16000
# Number of audio channels (1=mono, 2=stereo)
HA_CHANNELS=1
# VAD frame duration in milliseconds (10, 20, 30)
HA_FRAME_DURATION_MS=30
# Padding silence in milliseconds
HA_PADDING_MS=300

# === AUDIO ===
# Microphone selection (-1 for automatic detection)
HA_MICROPHONE_INDEX=-1
# Output device selection (-1 for automatic detection)
HA_OUTPUT_DEVICE_INDEX=-1
# Output sample rate for playback (-1 for automatic)
HA_OUTPUT_SAMPLE_RATE=-1

# === VOICE DETECTION (VAD) ===
# VAD sensitivity mode (0=least sensitive, 3=most sensitive)
HA_VAD_MODE=3
# How long to wait for silence before ending recording (seconds)
HA_SILENCE_THRESHOLD_SEC=1.5

# === INTERFACE & PERFORMANCE ===
# Enable visual animations (true/false)
HA_ANIMATIONS_ENABLED=true
# Show assistant responses as text on screen (true/false)
HA_RESPONSE_TEXT_ENABLED=true
# Show text listening indicator on screen (true/false)
HA_SHOW_LISTENING_INDICATOR=true

# === NETWORK ===
# Port for animation WebSocket server
ANIMATION_PORT=8765

# === WAKE WORD DETECTION ===
# Enable wake word detection (true/false)
HA_WAKE_WORD_ENABLED=true
# Comma-separated list of wake word models (alexa, jarvis, etc.)
HA_WAKE_WORD_MODELS=computer_v2
# Detection sensitivity threshold (0.0-1.0, higher = more sensitive)
HA_WAKE_WORD_THRESHOLD=0.5
# Voice activity threshold for wake words (0.0-1.0)
HA_WAKE_WORD_VAD_THRESHOLD=0.3
# Enable noise suppression for wake words (true/false)
HA_WAKE_WORD_NOISE_SUPPRESSION=false

# === MEDIA PLAYER VOLUME MANAGEMENT ===
# Comma-separated list of media player entities to manage during voice interactions
HA_MEDIA_PLAYER_ENTITIES=
# Target volume level during voice interactions (0.0-1.0)
HA_MEDIA_PLAYER_TARGET_VOLUME=0.3


# === AUDIO FEEDBACK ===
# Play activation/deactivation sounds (true/false)
HA_SOUND_FEEDBACK=false

# === DEBUG ===
# Enable detailed logging with file output (true/false)
DEBUG=false
